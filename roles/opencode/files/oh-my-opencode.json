{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.4"
    },
    "explore": {
      "model": "openai/gpt-5-nano-2025-08-07"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5-mini"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "atlas": {
      "model": "openai/gpt-5.4"
    }
  },
  "lsp": {
    "marksman": {
      "command": "marksman",
      "args": ["server"],
      "filetypes": [".md", ".markdown"]
    },
    "gopls": {
      "command": "gopls",
      "args": ["serve"],
      "filetypes": [".go"]
    },
    "phpactor": {
      "command": "phpactor",
      "args": ["language-server"],
      "filetypes": [".php"]
    },
    "typescript-language-server": {
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "filetypes": [".ts", ".tsx", ".js", ".jsx"]
    },
    "pylsp": {
      "command": "pylsp",
      "filetypes": [".py"]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5-mini"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "artistry": {
      "model": "openai/gpt-5-mini",
      "variant": "max"
    },
    "quick": {
      "model": "openai/gpt-5-nano-2025-08-07"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "writing": {
      "model": "openai/gpt-5-nano-2025-08-07"
    }
  }
}
